# GitLab Configuration
# URL of your GitLab instance API
GITLAB_BASE=https://gitlab.com/api/v4
# Token with read_api and read_repository scopes
GITLAB_TOKEN=your_token_here

# Script Paths
# Path to the CLI entry point (relative to dashboard root or absolute)
REVIEW_SCRIPT_PATH=../bin/review-gitlab-branches.js

# Working Directories
# Where repositories are cloned temporarily
WORK_DIR=../.work
# Where reports and history are stored
STORAGE_DIR=../storage

# Server Configuration
PORT=3001

# Analysis Toggles (1 = Disabled, 0 = Enabled)
REPORT_NO_GITLEAKS=0
REPORT_NO_SEMGREP=0
REPORT_NO_OSV=0
REPORT_NO_JSCPD=0
REPORT_NO_KNIP=0
REPORT_NO_DEP_CRUISER=0

# Operational Modes
# Set to true to skip installing dev dependencies
ANALYZE_OFFLINE_MODE=false
# Set to 1 to force using the internal .eslintrc.js
REPORT_USE_INTERNAL_ESLINT_CONFIG=0
