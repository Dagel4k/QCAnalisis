# GitLab Configuration
GITLAB_BASE=https://gitlab.com/api/v4
GITLAB_TOKEN=your_gitlab_token_here

# Script Paths (use absolute paths)
REVIEW_SCRIPT_PATH=/path/to/your/scripts/review-gitlab-branches.js
REPORT_SCRIPT_PATH=/path/to/your/scripts/generate-html-lint-report.js

# Working Directories
WORK_DIR=.work
STORAGE_DIR=storage

# Default Analysis Options
DEFAULT_IGNORE=**/*.pb.ts,**/proto/**,**/node_modules/**
DEFAULT_GLOBS=src/**/*.{ts,tsx,js,jsx}

# Dev Tools Installation (optional)
# If you have a meta package with dev dependencies
INSTALL_DEV_SPEC=file:/path/to/scriptc-dev-tools-0.1.0.tgz
ANALYZE_OFFLINE_MODE=false

# Server Configuration
PORT=3001
