{
  "name": "scriptc-linter",
  "displayName": "ScriptC Linter",
  "description": "Análisis estático en tiempo real impulsado por ScriptC. Detecta vulnerabilidades, malas prácticas y secretos hardcodeados mientras escribes.",
  "version": "0.0.1",
  "publisher": "scriptc",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile -- --production",
    "compile": "node scripts/build.js",
    "watch": "node scripts/build.js --watch"
  },
  "dependencies": {
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.1",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}
