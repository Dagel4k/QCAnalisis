{
  "name": "scriptc-linter",
  "displayName": "ScriptC: Real-time Security & Quality Auditor",
  "description": "Detect security vulnerabilities and code smells as you type. Zero-config: includes SonarJS + ESLint Security out of the box.",
  "version": "0.0.4",
  "icon": "logo.png",
  "publisher": "dagel4k",
  "author": "Daniel Pereda Chaidez",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "linter",
    "sast",
    "sonarjs",
    "code-quality",
    "static-analysis",
    "typescript",
    "javascript",
    "zero-config",
    "code-smell"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile -- --production",
    "compile": "node scripts/build.js",
    "watch": "node scripts/build.js --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dagel4k/QCAnalisis",
    "directory": "packages/vscode-extension"
  },
  "dependencies": {
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0",
    "vscode-languageclient": "^9.0.1"
  }
}